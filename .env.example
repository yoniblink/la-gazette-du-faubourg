# Développement local (sans Docker) — SQLite (chemin relatif au dossier prisma/)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL) — exemple :
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gazette?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"

NEXTAUTH_URL="http://localhost:3000"

# Admin (seed + db:admin)
ADMIN_EMAIL="admin@lagazettedufaubourg.local"
ADMIN_PASSWORD="changeme"
