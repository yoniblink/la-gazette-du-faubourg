# Développement local (sans Docker) — SQLite (chemin relatif au dossier prisma/)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL) — exemple :
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gazette?schema=public"

# Auth.js — generate with: openssl rand -base64 32 (obligatoire en prod / sur Vercel)
AUTH_SECRET="replace-with-a-long-random-string"
# Alias reconnu si tu n’as que NEXTAUTH_SECRET (ex. anciens projets)
# NEXTAUTH_SECRET=" même valeur que AUTH_SECRET "
AUTH_TRUST_HOST="true"

NEXTAUTH_URL="http://localhost:3000"
# Sur Vercel : Project → Settings → Environment Variables → AUTH_SECRET, NEXTAUTH_URL (URL du site, ex. https://ton-app.vercel.app)

# Admin (seed + db:admin)
ADMIN_EMAIL="admin@lagazettedufaubourg.local"
ADMIN_PASSWORD="changeme"

# Optionnel : PAT GitHub (scope « repo ») pour npm run github:publish sans navigateur
# GH_TOKEN="ghp_…"
