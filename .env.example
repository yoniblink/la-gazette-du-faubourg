# Prisma — Supabase : URL poolée (port 6543) pour l’app / le serverless
DATABASE_URL="postgres://postgres.PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Prisma — connexion directe (port 5432 sur db.PROJECT_REF) pour `prisma migrate`
DIRECT_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Intégration Vercel → Supabase : si seulement POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING
# sont définis, l’app les mappe vers DATABASE_URL / DIRECT_URL au chargement de Prisma.

# Supabase côté client / Edge (middleware). URL + clé « anon » (JWT eyJ… du dashboard, API publique).
# Soit NEXT_PUBLIC_SUPABASE_ANON_KEY, soit NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY (même valeur).
# Si les deux manquent, le middleware ignore Supabase (OK si vous n’utilisez que Prisma + NextAuth).
# NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Flipbook admin : PDF lourd sur Vercel (limite ~4,5 Mo) → upload direct Supabase Storage.
# Bucket + policy lecture publique : exécuter supabase/storage-flipbook-setup.sql dans SQL Editor
# (ou créer manuellement un bucket public « flipbook-pdf »).
# SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."  # jamais exposer au client ; souvent déjà sur Vercel
# FLIPBOOK_STORAGE_BUCKET="flipbook-pdf"

# Vidéos Reels (section Instagram) — bucket public, script : supabase/storage-instagram-reels-setup.sql
# INSTAGRAM_REELS_STORAGE_BUCKET="instagram-reels"

# Médiathèque admin (images articles) — requis sur Vercel ; script : supabase/storage-site-media-setup.sql
# MEDIA_STORAGE_BUCKET="site-media"
# Import WP → même bucket, préfixe admin-media/ (npm run import:wp-media). Forcer le disque local : IMPORT_WP_MEDIA_LOCAL=1
# Réimporter tout (supprime les lignes Media filename wp-* puis retéléverse) : npm run import:wp-media:resync
# Après import WP : recoller chaque article publié à son image (featured_media → Media wp-{id}-*) : npm run sync:article-covers
# Page WP /actualités/ (Elementor) : mêmes visuels que les tuiles manuelles : npm run sync:actualites-elementor-covers

# Media kit PDF (page /le-media-kit) — script : supabase/storage-media-kit-setup.sql
# MEDIA_KIT_STORAGE_BUCKET="media-kit"

# Flipbook : conversion PDF → images via iLovePDF API (https://developer.ilovepdf.com).
# ILOVEPDF_PUBLIC_KEY="…"
# ILOVEPDF_SECRET_KEY="…"
#
# FLIPBOOK_RENDER_MAX_PAGES="40"
# FLIPBOOK_RENDER_HALF_SPREAD_PX="480"
# FLIPBOOK_RENDER_DPR="2.75"
# FLIPBOOK_ILOVEPDF_DPI="300"
# Résolution pdf→JPEG iLovePDF (96–300).
# FLIPBOOK_RENDER_WEBP_QUALITY="90"
# FLIPBOOK_RENDER_WEBP_EFFORT : encodage WebP 0–6 (défaut 4 ; plus haut = plus lent, parfois plus léger).
# FLIPBOOK_RENDER_WEBP_EFFORT="4"
# FLIPBOOK_PDF_LAYOUT : auto | portrait | spread
# FLIPBOOK_PDF_LAYOUT="auto"

# Auth.js — openssl rand -base64 32 (sur Vercel : optionnel si secret dérivé)
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"

NEXTAUTH_URL="http://localhost:3000"

# Admin (seed + db:admin)
ADMIN_EMAIL="admin@lagazettedufaubourg.local"
ADMIN_PASSWORD="changeme"

# Optionnel : import WordPress → Prisma (DATABASE_URL requis)
# npm run import:wp-mode           → cat. WP « Mode » (id 16) → rubrique mode
# npm run import:wp-art-culture    → cat. WP « Arts » (id 17) → rubrique art-culture
# npm run import:wp-gastronomie    → cat. WP « Restauration » (id 18) → rubrique gastronomie
# npm run import:wp-rencontres     → slugs listés (page Rencontres) → rubrique rencontres
# WORDPRESS_IMPORT_BASE_URL="https://www.lagazettedufaubourg.fr"
# WORDPRESS_IMPORT_CATEGORY_ID="16"
# WORDPRESS_IMPORT_POST_SLUGS="slug-un,slug-deux"
# GAZETTE_IMPORT_CATEGORY_SLUG="mode"

# Optionnel : npm run github:publish
# GH_TOKEN="ghp_…"
