# Prisma — Supabase : URL poolée (port 6543) pour l’app / le serverless
DATABASE_URL="postgres://postgres.PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Prisma — connexion directe (port 5432 sur db.PROJECT_REF) pour `prisma migrate`
DIRECT_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Supabase côté client / Edge (middleware). Les deux sont requis pour rafraîchir la session ;
# sinon le middleware les ignore et l’app reste utilisable (évite MIDDLEWARE_INVOCATION_FAILED sur Vercel).
# NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Auth.js — openssl rand -base64 32 (sur Vercel : optionnel si secret dérivé)
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"

NEXTAUTH_URL="http://localhost:3000"

# Admin (seed + db:admin)
ADMIN_EMAIL="admin@lagazettedufaubourg.local"
ADMIN_PASSWORD="changeme"

# Optionnel : npm run github:publish
# GH_TOKEN="ghp_…"
