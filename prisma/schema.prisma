generator client {
  provider = "prisma-client-js"
}

// Local : SQLite (file:./dev.db). Supabase / prod : PostgreSQL (DATABASE_URL + DIRECT_URL).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum ArticleLayout {
  lead
  standard
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  tagline       String
  description   String
  imageSrc      String
  imageAlt      String
  sortOrder     Int       @default(0)
  showInMainNav Boolean   @default(true)
  articles      Article[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Article {
  id                 String        @id @default(cuid())
  slug               String
  title              String
  kicker             String?
  excerpt            String
  coverImageUrl       String
  coverImageAlt       String
  /** Recadrage (CSS object-position), ex. « 50% 30% » */
  coverObjectPosition String       @default("50% 50%")
  content            Json
  status             ArticleStatus @default(DRAFT)
  publishedAt        DateTime?
  authorName         String        @default("La Gazette")
  seoTitle           String?
  seoDescription     String?
  sourceUrl          String?
  layout             ArticleLayout @default(standard)
  featuredOnHome     Boolean       @default(false)
  featuredSortOrder  Int           @default(0)
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, status])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/** Vidéos type Reels affichées sur la section Instagram (fichiers sur Supabase Storage). */
model InstagramReel {
  id        String   @id @default(cuid())
  videoUrl  String
  posterUrl String?
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}
